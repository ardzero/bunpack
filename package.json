{
  "name": "create-bunpack",
  "description": "An opinionated base template for creating quick cli tools with Bun and typescript and a few helpful utilities.",
  "author": "Ard Astroid <ardastroid@gmail.com>",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ardzero/bunpack.git"
  },
  "homepage": "https://github.com/ardzero/bunpack",
  "bugs": {
    "url": "https://github.com/ardzero/bunpack/issues"
  },
  "bin": {
    "create-bunpack": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "bun run cli.ts",
    "build": "bun build cli.ts --outdir dist --target node --minify --sourcemap=external",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "bunpack",
    "bun",
    "cli",
    "boilerplate",
    "package",
    "packaging",
    "typescript"
  ],
  "module": "cli.ts",
  "type": "module",
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0"
  }
}
